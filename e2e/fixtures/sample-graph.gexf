<?xml version="1.0" encoding="UTF-8"?>
<gexf xmlns="http://gexf.net/1.3" version="1.3">
  <graph mode="static" defaultedgetype="directed">
    <attributes class="node">
      <attribute id="0" title="age" type="integer"/>
      <attribute id="1" title="active" type="boolean"/>
    </attributes>
    <attributes class="edge">
      <attribute id="0" title="weight" type="double"/>
    </attributes>
    <nodes>
      <node id="n1" label="Alice">
        <attvalues>
          <attvalue for="0" value="34"/>
          <attvalue for="1" value="true"/>
        </attvalues>
      </node>
      <node id="n2" label="Bob">
        <attvalues>
          <attvalue for="0" value="28"/>
          <attvalue for="1" value="false"/>
        </attvalues>
      </node>
      <node id="n3" label="Carol">
        <attvalues>
          <attvalue for="0" value="45"/>
          <attvalue for="1" value="true"/>
        </attvalues>
      </node>
    </nodes>
    <edges>
      <edge source="n1" target="n2" weight="0.8"/>
      <edge source="n2" target="n3" weight="1.2"/>
      <edge source="n1" target="n3" weight="0.5"/>
    </edges>
  </graph>
</gexf>
