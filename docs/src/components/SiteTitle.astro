---
/**
 * Override of Starlight's default SiteTitle component. Identical to the
 * default *except* the brand link points to `/` (the marketing homepage)
 * instead of `/docs` (the docs root). The wordmark is a brand mark — it
 * should always go to the brand home, regardless of which sub-app the
 * visitor is currently inside.
 *
 * In dev (docs on :4321, homepage on :5173), `/` is rewritten to
 * http://localhost:5173/ by the inline script in Header.astro.
 */
import { logos } from 'virtual:starlight/user-images'
import config from 'virtual:starlight/user-config'
const { siteTitle } = Astro.locals.starlightRoute
const homeHref = '/'
---

<a href={homeHref} class="site-title sl-flex" aria-label="Knotviz home">
  {
    config.logo && logos.dark && (
      <>
        <img
          class:list={{ 'light:sl-hidden print:hidden': !('src' in config.logo) }}
          alt={config.logo.alt}
          src={logos.dark.src}
          width={logos.dark.width}
          height={logos.dark.height}
        />
        {!('src' in config.logo) && (
          <img
            class="dark:sl-hidden print:block"
            alt={config.logo.alt}
            src={logos.light?.src}
            width={logos.light?.width}
            height={logos.light?.height}
          />
        )}
      </>
    )
  }
  <span class:list={{ 'sr-only': config.logo?.replacesTitle }} translate="no">
    {siteTitle}
  </span>
</a>
