{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Graph Data",
  "type": "object",
  "required": ["version", "nodes", "edges"],
  "properties": {
    "version": { "type": "string", "const": "1" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "properties": {
            "type": "object",
            "additionalProperties": {
              "oneOf": [
                { "type": "number" },
                { "type": "string" },
                { "type": "boolean" }
              ]
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target"],
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "label": { "type": "string" }
        }
      }
    }
  }
}
